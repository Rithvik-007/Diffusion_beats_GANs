runs/*/checkpoint_*.pt
runs/*/base_model.pt

# Raw latent tensor samples (not needed, PNGs are saved instead)
runs/*/samples/*.pt

# Debug scripts
debug_sample.py

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Documents (personal notes)
*.pdf
*.docx

# Sanity check output
sanity_check.png
